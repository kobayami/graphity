    "forks": 1,
    "warmup_iterations": 1,
    "warmup_time": "1s",
    "measurement_iterations": 3,
    "measurement_time": "1s",
    "jvm_stack": "-Xss16m"
  },
  "cases": [
    {
      "name": "build",
      "libraries": ["graphity", "jgrapht", "guava", "webgraph"],
      "algorithms": ["build"],
      "params": {
        "nodeCount": [10000, 100000],
        "shape": ["PATH", "TREE", "GNP_SPARSE", "GNP_DENSE", "CHAIN_OF_CLIQUES", "PATH_SHUFFLED", "GNP_DENSE_SHUFFLED", "CHAIN_OF_CLIQUES_SHUFFLED"]
      }
    },
    {
      "name": "scc",
      "libraries": ["graphity", "jgrapht", "guava", "webgraph"],
      "algorithms": ["scc"],
      "params": {
        "nodeCount": [10000, 100000],
        "shape": ["PATH", "TREE", "GNP_SPARSE", "GNP_DENSE", "CHAIN_OF_CLIQUES", "PATH_SHUFFLED", "GNP_DENSE_SHUFFLED", "CHAIN_OF_CLIQUES_SHUFFLED"]
      }
    },
    {
      "name": "toporder",
      "libraries": ["graphity", "jgrapht", "guava", "webgraph"],
