      }
    }
  ],
  "mem": {
    "enabled": true,
    "nodes": [10000, 100000],
    "shapes": ["PATH", "TREE", "GNP_SPARSE", "GNP_DENSE", "CHAIN_OF_CLIQUES", "PATH_SHUFFLED", "GNP_DENSE_SHUFFLED", "CHAIN_OF_CLIQUES_SHUFFLED"],
